FROM node:20-alpine AS builder

WORKDIR /app

# Install pnpm
RUN npm install -g pnpm

# Copy repository
COPY . .

# Install and build
RUN pnpm install
RUN pnpm run build

# Stage 2: Serve with Nginx
FROM nginx:alpine

# Copy built frontend
COPY --from=builder /app/artifacts/finance-tracker/dist /usr/share/nginx/html

# Copy custom Nginx configuration
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
