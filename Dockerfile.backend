FROM node:20-alpine

WORKDIR /app

# Install pnpm
RUN npm install -g pnpm

# Copy repository
COPY . .

# Install dependencies and build
RUN pnpm install
RUN pnpm --filter @workspace/api-server... run build

EXPOSE 3001
ENV PORT=3001
ENV NODE_ENV=production

# Run the API server
CMD ["node", "artifacts/api-server/dist/index.mjs"]
